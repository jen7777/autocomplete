<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10"
      alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.simple.Controller"
      style="-fx-padding: 20; -fx-background-color: linear-gradient(to bottom, #f5f7fa, #c3cfe2);">

    <TextField fx:id="inputField"
               promptText="Start typing..."
               prefWidth="400"
               style="-fx-font-size:16px; -fx-padding:10; -fx-background-radius:10; -fx-border-radius:10; -fx-border-color:#ccc;" />

    <ListView fx:id="suggestionList"
              prefWidth="400"
              maxHeight="150"
              style="-fx-background-radius:10; -fx-border-radius:10;" />

</VBox>
